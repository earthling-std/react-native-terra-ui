{
  "name": "terra-ui-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for react-native-terra-ui and its example app",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "example": "yarn workspace example-expo"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/earthling-std/react-native-terra-ui.git"
  },
  "author": "Hai Le <hai.le@elmosoftware.com.au> (https://github.com/earthling-std)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/earthling-std/react-native-terra-ui/issues"
  },
  "homepage": "https://github.com/earthling-std/react-native-terra-ui#readme",
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "packageManager": "yarn@4.11.0"
}
